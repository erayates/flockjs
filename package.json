{
  "name": "flockjs",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test --filter=./packages/*",
    "test:watch": "turbo run test:watch --filter=./packages/* --parallel",
    "typecheck": "turbo run typecheck",
    "typecheck:root": "tsc --noEmit -p tsconfig.json",
    "typecheck:all": "pnpm run typecheck && pnpm run typecheck:root",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "commitlint": "commitlint",
    "verify:tsconfig-extends": "node scripts/verify-tsconfig-extends.mjs",
    "prepare": "husky",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.22.0",
    "@vitest/coverage-v8": "^3.0.8",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.8"
  }
}
